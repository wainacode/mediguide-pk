# MediGuide Pakistan - Environment Configuration Template
# Copy this file to '.env' and fill in your Gemini API Key.
# Get your API key from Google AI Studio: https://aistudio.google.com/

# Your Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# The port the Express.js server will run on (optional, defaults to 3000)
PORT=3000
